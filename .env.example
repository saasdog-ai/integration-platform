# Application
APP_NAME=integration-platform
APP_ENV=development  # development, staging, production
LOG_LEVEL=INFO

# Database (shared PostgreSQL instance with import-export-orchestrator on port 5433)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/integration_platform
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE=3600
DATABASE_POOL_TIMEOUT=30

# API
API_HOST=0.0.0.0
API_PORT=8001  # Different from import-export-orchestrator (8000)

# JWT Authentication
AUTH_ENABLED=false
JWT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION
JWT_ALGORITHM=HS256
# For RS256/ES256 asymmetric algorithms:
# JWT_JWKS_URL=https://auth.example.com/.well-known/jwks.json
# JWT_ISSUER=https://auth.example.com
# JWT_AUDIENCE=integration-platform

# Cloud Provider (aws, azure, gcp, or empty for local)
CLOUD_PROVIDER=

# AWS Configuration (if CLOUD_PROVIDER=aws)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=  # For localstack: http://localhost:4566

# Queue Configuration
QUEUE_URL=  # SQS URL, Azure Queue connection string, or GCP subscription
QUEUE_WAIT_TIME_SECONDS=20

# Encryption (KMS)
KMS_KEY_ID=  # AWS KMS Key ID or Azure Key Vault key name

# Azure Configuration (if CLOUD_PROVIDER=azure)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_KEYVAULT_URL=

# GCP Configuration (if CLOUD_PROVIDER=gcp)
GCP_PROJECT_ID=
GCP_KMS_KEYRING=
GCP_KMS_KEY=

# Job Runner
JOB_RUNNER_MAX_WORKERS=5
JOB_RUNNER_ENABLED=true

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC

# CORS
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:4000"]
